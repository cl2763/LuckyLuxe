{
  "name": "lucky-luxe-api",
  "version": "0.1.0",
  "private": true,
  "description": "Local backend API for Lucky Luxe mini program and future web app.",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "dev:local": "node local-server.mjs",
    "dev:supabase": "node supabase-server.mjs",
    "start": "tsx src/main.ts",
    "start:supabase": "node supabase-server.mjs",
    "build": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:reset": "prisma db push --force-reset && tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^5.1.0",
    "pg": "^8.21.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
