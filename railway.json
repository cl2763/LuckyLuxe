{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "echo 'local-server.mjs is zero-dependency, no build needed'"
  },
  "deploy": {
    "startCommand": "node --experimental-sqlite apps/api/local-server.mjs",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 120,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
