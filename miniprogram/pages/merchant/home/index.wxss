page{background:#fbf8f5}
.page{padding:24rpx 26rpx 160rpx}
.topbar{display:flex;justify-content:space-between;align-items:center;margin-bottom:20rpx}
.greeting{font-size:36rpx;font-weight:600;color:#2d2826}
.date{font-size:24rpx;color:#8c8279;margin-top:8rpx}
.rolechip{font-size:22rpx;color:#9b7655;background:#f1e7df;border:1rpx solid #e7ddd4;border-radius:40rpx;padding:6rpx 20rpx}
.ai{background:#f7ede0;border:1rpx solid #e7ddd4;border-radius:22rpx;padding:22rpx;margin-bottom:20rpx}
.ai-h{font-size:24rpx;color:#9b7655;font-weight:600;margin-bottom:10rpx}
.ai-dot{color:#c8a47e}
.ai-headline{font-size:25rpx;color:#5c4630;line-height:1.6;margin-bottom:8rpx}
.bl{display:flex;gap:14rpx;margin-top:8rpx}
.dot{width:10rpx;height:10rpx;border-radius:50%;background:#9b7655;margin-top:12rpx;flex:0 0 auto}
.bl-t{font-size:24rpx;color:#5c4630;line-height:1.5}
.ai-empty{font-size:24rpx;color:#8c8279}
.todo{display:flex;flex-wrap:wrap;justify-content:space-between;margin-bottom:20rpx}
.chip{width:31.5%;background:#fff;border:1rpx solid #e7ddd4;border-radius:18rpx;padding:20rpx 0;text-align:center;margin-bottom:18rpx}
.chip.alert{border-left:6rpx solid #a34c48}
.n{font-size:40rpx;font-weight:600;color:#2d2826;line-height:1.1}
.n.nr{color:#a34c48}
.n.ng{color:#9b7655}
.n.lock{font-size:30rpx;color:#b6a99b}
.l{font-size:22rpx;color:#8c8279;margin-top:6rpx}
.rev{background:#f1e7df;border-radius:20rpx;padding:22rpx 24rpx}
.rev-l{font-size:24rpx;color:#8c8279}
.rev-lock{font-size:28rpx;color:#9b7655;font-weight:500;margin-top:10rpx}
