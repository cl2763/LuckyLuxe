page{background:#fbf8f5}
.page{padding:20rpx 26rpx 60rpx}
.empty{text-align:center;color:#8c8279;font-size:24rpx;padding:80rpx 0}
.t2{font-size:25rpx;color:#2d2826;font-weight:600;margin:20rpx 4rpx 14rpx}
.funnel{display:flex;flex-direction:column;gap:8rpx}
.fb{display:flex;align-items:center;justify-content:space-between;color:#fff;border-radius:10rpx;padding:16rpx 20rpx;min-width:120rpx}
.fl{font-size:23rpx}
.fn{font-size:26rpx;font-weight:700}
.fnote{font-size:21rpx;color:#b6a99b;margin:12rpx 4rpx 0}
.mets{display:flex;gap:12rpx;margin:18rpx 0}
.met{flex:1;background:#fff;border:1rpx solid #e7ddd4;border-radius:14rpx;padding:18rpx 12rpx;text-align:center}
.ml{font-size:20rpx;color:#8c8279}
.mv{font-size:32rpx;color:#9b7655;font-weight:700;margin-top:8rpx}
.card{background:#fff;border:1rpx solid #e7ddd4;border-radius:16rpx;overflow:hidden}
.brow{display:flex;align-items:center;padding:20rpx 22rpx;border-bottom:1rpx solid #f1e7df}
.brow:last-child{border-bottom:none}
.rank{width:38rpx;height:38rpx;border-radius:50%;background:#f1e7df;color:#9b7655;font-size:22rpx;font-weight:700;display:flex;align-items:center;justify-content:center;margin-right:14rpx;flex:0 0 auto}
.bname{flex:1;font-size:25rpx;color:#2d2826;min-width:0}
.bn{font-size:23rpx;color:#8c8279}
.none{text-align:center;color:#b6a99b;font-size:22rpx;padding:24rpx 0}
.note{font-size:21rpx;color:#b6a99b;line-height:1.6;margin-top:18rpx}
