page{background:#fbf8f5}
.page{padding:20rpx 26rpx 60rpx}
.seg{display:flex;background:#f1e7df;border-radius:12rpx;padding:5rpx;margin-bottom:18rpx}
.s{flex:1;text-align:center;font-size:24rpx;color:#8c8279;padding:14rpx 0;border-radius:9rpx}
.s.on{background:#fff;color:#2d2826;font-weight:600}
.card{background:#fff;border:1rpx solid #e7ddd4;border-radius:16rpx;margin-bottom:12rpx}
.crow{display:flex;align-items:center;gap:14rpx;padding:20rpx 20rpx}
.ci{flex:1;min-width:0}
.cn{font-size:27rpx;font-weight:600;color:#2d2826}
.cn.off{color:#b6a99b}
.cs{font-size:22rpx;color:#8c8279;margin-top:6rpx}
.sw{transform:scale(.8);flex:0 0 auto}
.empty{text-align:center;color:#b6a99b;font-size:23rpx;padding:40rpx 0}
.add{text-align:center;color:#9b7655;font-size:25rpx;border:1rpx dashed #d8c6b3;border-radius:14rpx;padding:22rpx 0;margin-top:4rpx}
.divider{height:1rpx;background:#e7ddd4;margin:26rpx 0}
.manual{text-align:center;font-size:27rpx;color:#fff;background:#2d2826;border-radius:16rpx;padding:26rpx 0;letter-spacing:1rpx}
.note{font-size:21rpx;color:#8c8279;line-height:1.7;margin-top:16rpx}
.note .b{color:#2d2826;font-weight:600}
