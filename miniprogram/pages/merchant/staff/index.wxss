page{background:#fbf8f5}
.page{padding:20rpx 26rpx 60rpx}
.topbar{display:flex;justify-content:space-between;align-items:center;margin-bottom:16rpx}
.h1{font-size:34rpx;font-weight:600;color:#2d2826}
.addbtn{font-size:23rpx;color:#fff;background:#c8a47e;border-radius:40rpx;padding:8rpx 20rpx}
.empty{text-align:center;color:#8c8279;font-size:24rpx;padding:60rpx 0}
.card{background:#fff;border:1rpx solid #e7ddd4;border-radius:16rpx;padding:16rpx 18rpx;margin-bottom:14rpx}
.top{display:flex;align-items:center;gap:14rpx}
.av{width:64rpx;height:64rpx;border-radius:50%;background:#f1e7df;color:#9b7655;display:flex;align-items:center;justify-content:center;font-weight:600;font-size:26rpx;flex:0 0 auto}
.info{flex:1;min-width:0}
.name{font-size:27rpx;font-weight:600;color:#2d2826}
.ttl{font-size:21rpx;color:#8c8279;font-weight:400;margin-left:8rpx}
.acct{font-size:22rpx;color:#9b7655;margin-top:6rpx}
.acct.none{color:#b6a99b}
.tag{font-size:21rpx;border-radius:40rpx;padding:4rpx 14rpx;flex:0 0 auto}
.tag.s{background:#e3eee8;color:#47735f}
.tag.n{background:#fbf8f5;color:#8c8279;border:1rpx solid #e7ddd4}
.btns{display:flex;gap:12rpx;margin-top:14rpx}
.b{flex:1;text-align:center;font-size:23rpx;border-radius:12rpx;padding:12rpx 0;background:#fbf8f5;border:1rpx solid #e7ddd4;color:#8c8279}
.b.p{background:#c8a47e;color:#fff;border-color:#c8a47e}
.b.d{border-color:#dcb3b0;color:#a34c48}
.b.full{flex:none;width:100%}
.note{font-size:22rpx;color:#8c8279;line-height:1.6;margin-top:8rpx}
