page{background:#fbf8f5}
.page{padding:16rpx 22rpx 60rpx}
.monthbar{display:flex;align-items:center;justify-content:space-between;margin-bottom:12rpx}
.marrow{font-size:40rpx;color:#9b7655;padding:0 20rpx}
.mtext{font-size:28rpx;font-weight:600;color:#2d2826}
.weekhead{display:flex;margin-bottom:6rpx}
.wh{flex:1;text-align:center;font-size:20rpx;color:#b6a99b}
.calgrid{display:flex;flex-wrap:wrap;background:#fff;border:1rpx solid #e7ddd4;border-radius:14rpx;padding:6rpx;margin-bottom:18rpx}
.cell{width:14.28%;height:96rpx;display:flex;flex-direction:column;align-items:center;justify-content:center;position:relative}
.cell.blank{visibility:hidden}
.cd{font-size:25rpx;color:#2d2826}
.cc{font-size:18rpx;color:#9b7655;margin-top:4rpx}
.cc.rest{color:#a3703f}
.cell.closed .cd{color:#c7b9ab}
.cell.sel{background:#c8a47e;border-radius:12rpx}
.cell.sel .cd,.cell.sel .cc{color:#fff}
.dayhead{display:flex;justify-content:space-between;align-items:center;margin-bottom:12rpx}
.dh-t{font-size:26rpx;font-weight:600;color:#2d2826}
.batchbtn{font-size:22rpx;color:#9b7655;background:#f1e7df;border:1rpx solid #e7ddd4;border-radius:40rpx;padding:6rpx 18rpx}
.empty{text-align:center;color:#8c8279;font-size:24rpx;padding:50rpx 0}
.row{display:flex;align-items:center;justify-content:space-between;background:#fff;border:1rpx solid #e7ddd4;border-radius:14rpx;padding:14rpx 16rpx;margin-bottom:12rpx}
.rleft{display:flex;align-items:center;gap:14rpx}
.av{width:56rpx;height:56rpx;border-radius:50%;background:#f1e7df;color:#9b7655;display:flex;align-items:center;justify-content:center;font-weight:600;font-size:24rpx}
.rname{font-size:26rpx;font-weight:500;color:#2d2826}
.rsub{font-size:22rpx;color:#8c8279;margin-top:4rpx}
.rright{display:flex;align-items:center;gap:8rpx}
.tpick{font-size:22rpx;color:#9b7655;background:#fbf8f5;border:1rpx solid #e7ddd4;border-radius:10rpx;padding:6rpx 12rpx}
.dash{color:#b6a99b;font-size:22rpx}
.tog{font-size:22rpx;border-radius:40rpx;padding:6rpx 20rpx;background:#fbf8f5;border:1rpx solid #e7ddd4;color:#8c8279}
.tog.on{background:#e3eee8;border-color:#cfe0d7;color:#47735f}
.bksec{margin:6rpx 0 16rpx}
.bkhead{font-size:26rpx;font-weight:600;color:#2d2826;margin-bottom:10rpx}
.bkn{font-size:20rpx;color:#9b7655;background:#f1e7df;border-radius:40rpx;padding:2rpx 12rpx;margin-left:6rpx}
.bkrow{display:flex;align-items:center;gap:14rpx;background:#fff;border:1rpx solid #e7ddd4;border-radius:14rpx;padding:14rpx 16rpx;margin-bottom:10rpx}
.bktime{font-size:24rpx;font-weight:600;color:#9b7655;flex:0 0 auto;width:80rpx}
.bkmain{flex:1;min-width:0}
.bkname{font-size:25rpx;color:#2d2826}
.bkcare{font-size:21rpx;color:#a34c48}
.bksub{font-size:21rpx;color:#8c8279;margin-top:4rpx}
.bktag{font-size:21rpx;color:#8c8279;background:#fbf8f5;border:1rpx solid #e7ddd4;border-radius:40rpx;padding:4rpx 14rpx;flex:0 0 auto}
.applybtn{text-align:center;background:#c8a47e;color:#fff;border-radius:14rpx;padding:20rpx;font-size:26rpx;font-weight:500;margin:8rpx 0 20rpx}
.reqsec{margin-top:8rpx}
.reqhead{font-size:26rpx;font-weight:600;color:#2d2826;margin-bottom:10rpx}
.reqn{font-size:20rpx;color:#a34c48;background:#f3e1df;border-radius:40rpx;padding:2rpx 12rpx;margin-left:6rpx}
.reqcard{background:#fff;border:1rpx solid #e7ddd4;border-radius:14rpx;padding:14rpx 16rpx;margin-bottom:12rpx}
.reqline{font-size:25rpx;color:#2d2826}
.reqnote{font-size:22rpx;color:#8c8279;margin-top:6rpx}
.reqbtns{display:flex;gap:10rpx;margin-top:12rpx}
.rb{flex:1;text-align:center;font-size:21rpx;border-radius:10rpx;padding:10rpx 0;background:#fbf8f5;border:1rpx solid #e7ddd4;color:#8c8279}
.rb.p{background:#c8a47e;color:#fff;border-color:#c8a47e}
.rb.d{border-color:#dcb3b0;color:#a34c48}
.mask{position:fixed;inset:0;background:rgba(45,40,38,.35);z-index:40}
.sheet{position:fixed;left:0;right:0;bottom:0;background:#fff;border-top-left-radius:22rpx;border-top-right-radius:22rpx;padding:16rpx 26rpx calc(24rpx + env(safe-area-inset-bottom));z-index:41}
.sh-bar{width:64rpx;height:8rpx;border-radius:4rpx;background:#e7ddd4;margin:0 auto 14rpx}
.sh-title{font-size:28rpx;font-weight:600;color:#2d2826;margin-bottom:14rpx}
.sh-techs{display:flex;flex-wrap:wrap;gap:12rpx;margin-bottom:16rpx}
.sh-tech{display:flex;align-items:center;gap:8rpx;border:1rpx solid #e7ddd4;border-radius:40rpx;padding:8rpx 16rpx;font-size:24rpx;color:#2d2826}
.sh-tech.on{background:#f1e7df;border-color:#c8a47e}
.ck{width:30rpx;height:30rpx;border-radius:7rpx;border:2rpx solid #c8a47e;display:flex;align-items:center;justify-content:center;color:#9b7655;font-size:20rpx}
.sh-tech.on .ck{background:#c8a47e;color:#fff}
.sh-mode{display:flex;gap:12rpx;margin-bottom:14rpx}
.mopt{flex:1;text-align:center;padding:14rpx;border-radius:12rpx;border:1rpx solid #e7ddd4;color:#8c8279;font-size:26rpx}
.mopt.on{background:#c8a47e;border-color:#c8a47e;color:#fff}
.sh-time{display:flex;align-items:center;gap:12rpx;margin-bottom:16rpx}
.sh-lb{font-size:24rpx;color:#8c8279}
.sh-btns{display:flex;gap:14rpx}
.sbtn{flex:1;text-align:center;padding:20rpx;border-radius:14rpx;border:1rpx solid #e7ddd4;color:#8c8279;font-size:28rpx}
.sbtn.p{flex:2;background:#c8a47e;color:#fff;border-color:#c8a47e}
