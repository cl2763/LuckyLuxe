.services-page {
  padding: 18rpx 0 180rpx;
  overflow: hidden;
}

.services-page .page-title {
  margin: 0 18rpx;
}

.type-switch {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8rpx;
  margin: 0 0;
  padding: 8rpx;
  border: 1rpx solid #eadfd7;
  border-radius: 18rpx;
  background: #fff;
}

.type-tab {
  min-width: 0;
  height: 76rpx;
  border-radius: 14rpx;
  color: #8a7f78;
  font-size: 32rpx;
  font-weight: 760;
  white-space: nowrap;
}

.type-tab.active {
  background: #2b2b2b;
  color: #fff;
}

.service-layout {
  display: flex;
  gap: 0;
  height: calc(100vh - 286rpx - env(safe-area-inset-bottom));
  margin-top: 20rpx;
  overflow: hidden;
}

.category-list {
  width: 240rpx;
  flex: none;
  border-radius: 0 14rpx 14rpx 0;
  background: rgba(255, 255, 255, 0.48);
}

.category-item {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 94rpx;
  padding: 0 18rpx;
  border-radius: 14rpx;
  color: #8a7f78;
  font-size: 25rpx;
  font-weight: 700;
  line-height: 1.2;
  text-align: center;
  white-space: nowrap;
}

.category-item text {
  display: block;
  width: 100%;
  overflow: visible;
  white-space: nowrap;
}

.category-item.active {
  background: #fff;
  color: #3a2e2a;
  font-weight: 780;
}

.service-list {
  flex: 1;
  min-width: 0;
  height: 100%;
  padding-right: 0;
}

.service-card {
  display: block;
  width: 100%;
  min-width: 0;
  margin: 0 0 18rpx;
  padding: 14rpx;
  border-radius: 16rpx;
  text-align: left;
  box-sizing: border-box;
}

.service-visual {
  width: 100%;
  height: 178rpx;
  border-radius: 14rpx;
  display: block;
}

.service-info {
  padding: 18rpx 6rpx 4rpx;
}

.service-name {
  color: #342b28;
  font-size: 32rpx;
  font-weight: 800;
  line-height: 1.25;
}

.service-desc {
  display: -webkit-box;
  margin-top: 10rpx;
  overflow: hidden;
  color: #8a7f78;
  font-size: 25rpx;
  font-weight: 600;
  line-height: 1.5;
  text-overflow: ellipsis;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.service-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx;
  margin-top: 16rpx;
  color: #8a7f78;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.35;
}

.service-meta .price {
  color: #c39b76;
}
