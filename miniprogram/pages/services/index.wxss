.services-page {
  padding: 22rpx 0 180rpx;
  overflow: hidden;
}

.type-switch {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8rpx;
  margin: 0 18rpx;
  padding: 8rpx;
  border: 1rpx solid #eadfd7;
  border-radius: 18rpx;
  background: #fff;
}

.type-tab {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 0;
  height: 76rpx;
  border-radius: 14rpx;
  color: #8a7f78;
  font-size: 30rpx;
  font-weight: 760;
  line-height: 1;
  white-space: nowrap;
}

.type-tab.active {
  background: #2b2b2b;
  color: #fff;
}

.service-layout {
  display: flex;
  gap: 16rpx;
  width: 100vw;
  height: calc(100vh - 190rpx - env(safe-area-inset-bottom));
  margin-top: 20rpx;
  overflow: hidden;
}

.category-list {
  width: 224rpx;
  min-width: 224rpx;
  max-width: 224rpx;
  flex: none;
  height: 100%;
  border-radius: 0;
  background: rgba(255, 255, 255, 0.5);
  box-sizing: border-box;
}

.category-item {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  min-width: 100%;
  max-width: 100%;
  height: 94rpx;
  margin: 0;
  padding: 0;
  border: 0;
  border-radius: 0;
  background: transparent;
  color: #8a7f78;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 1.15;
  text-align: center;
  white-space: nowrap;
  box-sizing: border-box;
  overflow: visible;
}

.category-item text {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  max-width: 100%;
  overflow: visible;
  white-space: nowrap;
  text-align: center;
  transform: none;
  text-indent: 0;
}

.category-item.active {
  background: #fff;
  color: #342b28;
  font-weight: 780;
}

.service-list {
  flex: 1;
  display: block;
  width: auto;
  min-width: 0;
  max-width: 100%;
  height: 100%;
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

.service-list-inner {
  display: flex;
  flex-direction: column;
  align-items: stretch;
  justify-content: flex-start;
  gap: 18rpx;
  width: 100%;
  min-width: 100%;
  max-width: 100%;
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

.service-card {
  display: block;
  width: 100%;
  min-width: 100%;
  max-width: 100%;
  margin: 0;
  padding: 16rpx;
  border-right: 0;
  border-left: 0;
  border-radius: 0;
  text-align: left;
  line-height: 1.2;
  box-sizing: border-box;
}

.service-visual {
  width: 100%;
  height: 176rpx;
  border-radius: 14rpx;
  display: block;
}

.service-info {
  padding: 18rpx 6rpx 4rpx;
}

.service-name {
  color: #342b28;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.25;
}

.service-desc {
  display: -webkit-box;
  margin-top: 10rpx;
  overflow: hidden;
  color: #8a7f78;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 1.5;
  text-overflow: ellipsis;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.service-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx 18rpx;
  margin-top: 16rpx;
  color: #8a7f78;
  font-size: 23rpx;
  font-weight: 700;
  line-height: 1.35;
}

.service-meta .price {
  color: #c39b76;
}

.quote-hint {
  margin-top: 10rpx;
  color: #a78260;
  font-size: 22rpx;
  font-weight: 800;
  line-height: 1.35;
}
