<view class="page me-page">
  <view class="member-card">
    <block wx:if="{{isLoggedIn}}">
      <view class="member-top">
        <image class="avatar" src="{{member.avatarUrl || '/assets/images/member-profile.jpg'}}" mode="aspectFill"></image>
        <view>
          <view class="nickname">{{member.nickname}}</view>
          <button class="level-pill" bindtap="goMemberBenefits">
            <text>{{member.memberLevel}}</text>
            <text class="level-more">权益</text>
          </button>
        </view>
        <view class="member-code" bindtap="showMemberCode">
          <view class="code-grid">
            <view></view><view></view><view></view>
            <view></view><view></view><view></view>
            <view></view><view></view><view></view>
          </view>
          <text>{{member.memberCode}}</text>
        </view>
      </view>

      <view wx:if="{{!member.profileComplete}}" class="profile-pending">
        <view class="profile-pending-title">{{lang === 'en' ? 'Signed in with WeChat' : '微信身份已登录'}}</view>
        <view class="profile-pending-desc">{{lang === 'en' ? 'Avatar and nickname can be completed later. Member data and booking access are already available.' : '头像昵称可稍后完善，不影响查看会员资料、订单与预约。'}}</view>
        <button class="profile-pending-btn" bindtap="openProfilePanel">{{lang === 'en' ? 'Complete profile' : '完善头像昵称'}}</button>
      </view>

      <view class="growth-block">
        <view class="growth-head">
          <text>{{t.growth}}</text>
          <text>{{member.growthValue}} / {{member.nextLevelValue}}</text>
        </view>
        <view class="growth-track">
          <view class="growth-fill" style="width: {{growthPercent}}%;"></view>
        </view>
        <view class="growth-note">{{member.growthNote}}</view>
      </view>

      <view class="member-assets">
        <view>
          <text>{{member.points}}</text>
          <text>{{t.points}}</text>
        </view>
        <view>
          <text>{{member.couponCount}}</text>
          <text>{{t.coupons}}</text>
        </view>
        <view>
          <text>CAD ${{member.balance}}</text>
          <text>{{t.balance}}</text>
        </view>
      </view>

      <view class="member-extra">
        <view>{{t.totalSpent}} CAD ${{member.totalSpent}}</view>
        <view>{{t.visits}} {{member.visits}} {{t.times}}</view>
      </view>
    </block>
    <block wx:else>
      <view class="guest-profile">
        <view class="guest-avatar">LL</view>
        <view class="guest-copy">
          <view class="nickname">{{lang === 'en' ? 'Guest user' : '游客用户'}}</view>
          <view class="guest-desc">{{lang === 'en' ? 'Sign in to view membership level, orders, coupons and balance.' : '登录后可查看会员等级、订单、优惠券与储值余额。'}}</view>
        </view>
      </view>
      <button class="member-login-btn" bindtap="openLoginPanel">
        {{lang === 'en' ? 'Sign in to continue' : '登录查看会员权益'}}
      </button>
      <view class="guest-footnote">{{lang === 'en' ? 'Protected entries below will ask you to sign in first.' : '下方会员功能需要登录后使用。'}}</view>
    </block>
  </view>

  <view class="section">
    <view class="section-head">
      <view class="section-title" bindtap="goOrders" data-status="all">{{t.orders}}</view>
      <view class="section-note" bindtap="goOrders" data-status="all">{{t.all}}</view>
    </view>
    <view class="order-entry card me-module-card">
      <button bindtap="goOrders" data-status="pending_service">
        <text>{{counts.pending_service}}</text>
        <text>{{t.statusPendingService}}</text>
      </button>
      <button bindtap="goOrders" data-status="completed">
        <text>{{counts.completed}}</text>
        <text>{{t.statusCompleted}}</text>
      </button>
      <button bindtap="goOrders" data-status="cancelled">
        <text>{{counts.cancelled}}</text>
        <text>{{t.statusCancelled}}</text>
      </button>
      <button bindtap="goOrders" data-status="after_sales">
        <text>{{counts.after_sales}}</text>
        <text>{{t.statusAfterSales}}</text>
      </button>
    </view>
  </view>

  <view class="section">
    <view class="section-head">
      <view class="section-title" bindtap="goOrders" data-status="all">{{t.recent}}</view>
      <view class="section-note" bindtap="goOrders" data-status="all">Records</view>
    </view>
    <view class="recent-list">
      <block wx:if="{{recentOrders.length}}">
        <block wx:for="{{recentOrders}}" wx:key="_id">
          <view class="recent-card card me-module-card" bindtap="goOrderDetail" data-id="{{item._id}}">
            <image class="recent-image" src="{{item.serviceImage}}" mode="aspectFill"></image>
            <view class="recent-info">
              <view class="recent-top">
                <text>{{item.serviceName}}</text>
                <text>{{item.statusText}}</text>
              </view>
              <view class="recent-meta">
                <text>{{item.appointment.date}}</text>
                <text>{{item.appointment.time}}</text>
              </view>
              <view class="recent-pay">{{t.paidDeposit}} CAD ${{item.payableAmount}}</view>
            </view>
          </view>
        </block>
      </block>
      <view wx:else class="empty-protected card" bindtap="goOrders" data-status="all">
        <text>{{lang === 'en' ? 'Sign in to view recent consumption.' : '登录后查看近期消费记录。'}}</text>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-head">
      <view class="section-title">{{t.functions}}</view>
    </view>
    <view class="menu-grid">
      <button class="menu-card card" bindtap="goAssets">
        <image class="menu-icon" src="/assets/images/nail-luxe.jpg" mode="aspectFill"></image>
        <view class="menu-title">{{t.assets}}</view>
        <view class="menu-desc">{{t.assetsDesc}}</view>
      </button>
      <button class="menu-card card" bindtap="goStore">
        <image class="menu-icon" src="/assets/images/store-cover.jpg" mode="aspectFill"></image>
        <view class="menu-title">{{t.store}}</view>
        <view class="menu-desc">{{t.storeDesc}}</view>
      </button>
      <button class="menu-card card" bindtap="openProtectedFeature">
        <image class="menu-icon" src="/assets/images/nail-french.jpg" mode="aspectFill"></image>
        <view class="menu-title">{{t.coupons}}</view>
        <view class="menu-desc">{{t.couponsDesc}}</view>
      </button>
      <button class="menu-card card" bindtap="openProtectedFeature">
        <image class="menu-icon" src="/assets/images/lash-volume.jpg" mode="aspectFill"></image>
        <view class="menu-title">{{t.giftCard}}</view>
        <view class="menu-desc">{{t.later}}</view>
      </button>
      <button class="menu-card card" bindtap="openProtectedFeature">
        <image class="menu-icon" src="/assets/images/nail-jp.jpg" mode="aspectFill"></image>
        <view class="menu-title">{{t.pointsMall}}</view>
        <view class="menu-desc">{{t.comingSoon}}</view>
      </button>
    </view>
  </view>

  <view wx:if="{{isLoggedIn}}" class="account-actions card">
    <view class="auth-title">{{lang === 'en' ? 'Signed in' : '已登录'}}</view>
    <view class="auth-desc">{{lang === 'en' ? 'You can sign out for guest testing.' : '如需测试未登录状态，可在这里退出。'}}</view>
    <button class="account-btn danger" bindtap="logout">{{lang === 'en' ? 'Sign out' : '退出登录'}}</button>
  </view>

  <view wx:if="{{authModalVisible}}" class="auth-mask">
    <view class="auth-panel simple-login-panel">
      <button class="auth-close" bindtap="closeLoginPanel">×</button>

      <view wx:if="{{authModalMode === 'login'}}" class="simple-login-body">
        <image class="simple-login-avatar" src="/assets/images/member-profile.jpg" mode="aspectFill"></image>
        <view class="simple-login-title">{{lang === 'en' ? 'Lucky Luxe' : 'Lucky Luxe'}}</view>
        <view class="simple-login-desc">{{lang === 'en' ? 'Sign in with WeChat to view orders and member benefits.' : '微信一键登录后可查看订单与会员权益。'}}</view>
      </view>

      <view wx:else class="profile-edit-body">
        <view class="profile-edit-title">{{lang === 'en' ? 'Complete member profile' : '完善会员资料'}}</view>
        <view class="profile-edit-desc">{{lang === 'en' ? 'Choose an avatar and enter a nickname for in-store member verification.' : '选择头像并填写昵称，方便到店核对会员资料。'}}</view>

        <view class="profile-avatar-row">
          <image wx:if="{{authProfile.avatarUrl}}" class="profile-edit-avatar" src="{{authProfile.avatarUrl}}" mode="aspectFill"></image>
          <image wx:else class="profile-edit-avatar" src="/assets/images/member-profile.jpg" mode="aspectFill"></image>
          <view class="profile-avatar-copy">
            <text>{{authProfile.avatarUrl ? (lang === 'en' ? 'Avatar selected' : '已选择头像') : (lang === 'en' ? 'Avatar' : '头像')}}</text>
            <text>{{lang === 'en' ? 'Use the native WeChat avatar picker.' : '使用微信原生头像选择器。'}}</text>
          </view>
        </view>
        <button class="native-avatar-button" open-type="chooseAvatar" bindtap="onAvatarTap" bindchooseavatar="onChooseAvatar">
          {{authProfile.avatarUrl ? (lang === 'en' ? 'Choose another WeChat avatar' : '重新选择微信头像') : (lang === 'en' ? 'Choose WeChat avatar' : '选择微信头像')}}
        </button>

        <view class="profile-field">
          <view class="profile-label">{{lang === 'en' ? 'WeChat nickname' : '微信昵称'}}</view>
          <input class="profile-input" type="nickname" placeholder="{{lang === 'en' ? 'Tap to use nickname suggestions' : '点击输入，可使用微信昵称建议'}}" value="{{authProfile.nickname}}" bindinput="inputNickname" />
        </view>
      </view>

      <view class="auth-footer simple-login-footer">
        <button wx:if="{{authModalMode === 'login'}}" class="privacy-check" open-type="agreePrivacyAuthorization" bindtap="onPrivacyTap" bindagreeprivacyauthorization="onAgreePrivacyAuthorization">
          <view class="privacy-box {{authProfile.privacyChecked ? 'checked' : ''}}">{{authProfile.privacyChecked ? '✓' : ''}}</view>
          <view class="privacy-copy">
            <text class="privacy-main">{{lang === 'en' ? 'I have read and agree to the Lucky Luxe privacy policy.' : '我已阅读并同意 Lucky Luxe 隐私政策'}}</text>
            <text class="privacy-sub">{{lang === 'en' ? 'Authorize WeChat login for member services.' : '授权使用微信登录会员服务'}}</text>
          </view>
        </button>
        <button class="finish-button {{canFinishLogin ? '' : 'disabled'}}" disabled="{{!canFinishLogin}}" bindtap="finishLogin">
          {{authModalMode === 'profile' ? (lang === 'en' ? 'Save profile' : '保存资料') : (lang === 'en' ? 'WeChat one-tap login' : '微信一键登录')}}
        </button>
      </view>
    </view>
  </view>
</view>
