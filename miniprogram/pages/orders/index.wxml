<view class="page orders-page">
  <scroll-view class="tabs" scroll-x>
    <block wx:for="{{tabs}}" wx:key="key">
      <button class="tab {{activeStatus === item.key ? 'active' : ''}}" bindtap="switchStatus" data-status="{{item.key}}">{{item.label}}</button>
    </block>
  </scroll-view>

  <block wx:if="{{orders.length}}">
    <view class="orders-list">
      <block wx:for="{{orders}}" wx:key="_id">
        <view class="order-card card" bindtap="goDetail" data-id="{{item._id}}">
          <view class="order-head">
            <text>{{item.serviceName}}</text>
            <text class="status">{{item.statusText}}</text>
          </view>
          <view class="order-body">
            <image class="mini-visual" src="{{item.serviceImage}}" mode="aspectFill"></image>
            <view class="order-info">
              <view class="order-time">{{item.appointment.date}} {{item.appointment.time}}</view>
              <view class="muted">{{item.store.storeName}}</view>
              <view class="price" wx:if="{{item.status === 'completed'}}">已结清 CAD ${{item.servicePrice}}</view>
              <view class="price" wx:elif="{{item.status === 'cancelled' || item.status === 'after_sales'}}">总价 CAD ${{item.servicePrice}}</view>
              <view class="price" wx:else>定金 ${{item.payableAmount}} 已付 · 到店应付 ${{item.finalDue}}</view>
            </view>
          </view>
        </view>
      </block>
    </view>
  </block>

  <view wx:else class="empty">
    <view class="empty-title">{{t.emptyTitle}}</view>
    <view>{{t.emptyText}}</view>
    <button class="btn btn-primary empty-btn" bindtap="goServices">{{t.book}}</button>
  </view>
</view>
