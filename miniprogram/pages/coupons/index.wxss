page{background:#fbf8f5}
.pg{padding:22rpx 26rpx 60rpx}
.seg{display:flex;background:#f1e7df;border-radius:12rpx;padding:5rpx;margin-bottom:12rpx}
.s{flex:1;text-align:center;font-size:24rpx;color:#8c8279;padding:14rpx 0;border-radius:9rpx}
.s.on{background:#fff;color:#2d2826;font-weight:600}
.demobar{font-size:20rpx;color:#b5731f;background:#fff4e6;border:1rpx solid #f0d9b8;border-radius:10rpx;padding:8rpx 12rpx;margin-bottom:14rpx;text-align:center}
.coupon{display:flex;align-items:stretch;border:1rpx dashed #c8a47e;border-radius:12rpx;overflow:hidden;margin-bottom:12rpx;background:#fff}
.coupon.dead{opacity:.55;border-style:solid;border-color:#e7ddd4}
.amt{background:#f4ece3;color:#9b7655;display:flex;flex-direction:column;align-items:center;justify-content:center;min-width:130rpx;padding:16rpx}
.amt .b{font-size:38rpx;font-weight:700}
.amt .u{font-size:19rpx;margin-top:2rpx}
.info{flex:1;padding:16rpx 18rpx;display:flex;flex-direction:column;justify-content:center}
.cn{font-size:26rpx;font-weight:600;color:#2d2826}
.ce{font-size:21rpx;color:#8c8279;margin-top:6rpx}
.qrbtn{display:flex;flex-direction:column;align-items:center;justify-content:center;gap:6rpx;padding:0 20rpx;border-left:1rpx dashed #e7ddd4;color:#9b7655;font-size:20rpx}
.qricon{width:36rpx;height:36rpx;display:flex;flex-wrap:wrap;gap:4rpx}
.qd{width:14rpx;height:14rpx;background:#9b7655;border-radius:2rpx}
.empty{background:#fff;border:1rpx solid #e7ddd4;border-radius:16rpx;padding:56rpx 34rpx;text-align:center}
.et{font-size:26rpx;color:#8c8279}
.ed{font-size:22rpx;color:#b6a99b;line-height:1.6;margin-top:12rpx}
.mask{position:fixed;inset:0;background:rgba(45,40,38,.5);display:flex;align-items:center;justify-content:center;z-index:50}
.qrcard{background:#fff;border-radius:20rpx;padding:34rpx 30rpx;width:560rpx;text-align:center}
.qname{font-size:30rpx;font-weight:700;color:#2d2826}
.qtip{font-size:22rpx;color:#8c8279;margin-top:8rpx}
.qr{width:420rpx;height:420rpx;margin:24rpx auto;display:flex;flex-wrap:wrap;background:#fff;padding:14rpx;border:1rpx solid #eee;box-sizing:content-box}
.qc{width:20rpx;height:20rpx;background:#fff}
.qc.on{background:#2d2826}
.qcode{font-size:26rpx;color:#9b7655;letter-spacing:2rpx;font-weight:600}
.qclose{margin-top:22rpx;font-size:25rpx;color:#8c8279;background:#f1e7df;border-radius:40rpx;padding:14rpx 0}
