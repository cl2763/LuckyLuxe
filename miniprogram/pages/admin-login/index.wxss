.admin-login-page {
  padding: 42rpx 28rpx 180rpx;
}

.login-card {
  padding: 42rpx 32rpx;
  border-radius: 22rpx;
}

.login-logo {
  width: 92rpx;
  height: 92rpx;
  display: block;
  margin-bottom: 24rpx;
  border-radius: 50%;
  background: #2b2b2b;
}

.login-title {
  color: #241f1d;
  font-size: 42rpx;
  font-weight: 880;
  line-height: 1.15;
}

.login-desc,
.login-note {
  margin-top: 12rpx;
  color: #8a7f78;
  font-size: 25rpx;
  font-weight: 600;
  line-height: 1.45;
}

.field {
  margin-top: 28rpx;
}

.field text {
  display: block;
  margin-bottom: 12rpx;
  color: #342b28;
  font-size: 25rpx;
  font-weight: 800;
}

.field input {
  height: 86rpx;
  padding: 0 24rpx;
  border: 1rpx solid #eadfd7;
  border-radius: 16rpx;
  background: #fffaf6;
  color: #342b28;
  font-size: 27rpx;
  box-sizing: border-box;
}

.login-btn {
  width: 100%;
  margin-top: 34rpx;
}
