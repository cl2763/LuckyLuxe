.admin-page {
  padding: 24rpx 24rpx 180rpx;
}

.admin-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 22rpx;
}

.eyebrow {
  color: #c6a27e;
  font-size: 22rpx;
  font-weight: 850;
  text-transform: uppercase;
}

.admin-title {
  margin-top: 6rpx;
  color: #241f1d;
  font-size: 42rpx;
  font-weight: 880;
  line-height: 1.1;
}

.logout {
  width: 112rpx;
  height: 58rpx;
  flex: none;
  border: 1rpx solid #eadfd7;
  border-radius: 999rpx;
  background: #fff;
  color: #5e514b;
  font-size: 23rpx;
  font-weight: 760;
}

.metric-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
}

.metric {
  min-height: 126rpx;
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  justify-content: space-between;
  text-align: left;
}

.metric text:first-child {
  color: #8a7f78;
  font-size: 23rpx;
  font-weight: 700;
}

.metric text:last-child {
  color: #342b28;
  font-size: 40rpx;
  font-weight: 880;
}

.nav-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 18rpx;
}

.nav-card {
  height: 76rpx;
  border: 1rpx solid #eadfd7;
  border-radius: 16rpx;
  background: #fff;
  color: #5e514b;
  font-size: 25rpx;
  font-weight: 800;
}

.nav-card.active {
  border-color: #2b2b2b;
  background: #2b2b2b;
  color: #fff;
}

.list {
  display: grid;
  gap: 14rpx;
}

.admin-booking,
.tech-row,
.service-row,
.customer-row {
  padding: 20rpx;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  text-align: left;
  box-sizing: border-box;
}

.booking-main {
  flex: 1;
  min-width: 0;
}

.booking-title,
.tech-name {
  color: #342b28;
  font-size: 28rpx;
  font-weight: 850;
  line-height: 1.25;
}

.booking-meta,
.booking-route {
  margin-top: 8rpx;
  color: #8a7f78;
  font-size: 23rpx;
  font-weight: 650;
  line-height: 1.35;
}

.booking-route {
  color: #7a6250;
}

.status-pill {
  flex: none;
  max-width: 188rpx;
  padding: 10rpx 14rpx;
  border-radius: 999rpx;
  background: #f3ebe4;
  color: #8a684c;
  font-size: 21rpx;
  font-weight: 800;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.tech-stats {
  display: grid;
  gap: 8rpx;
  flex: none;
  color: #c39b76;
  font-size: 23rpx;
  font-weight: 850;
  text-align: right;
}
