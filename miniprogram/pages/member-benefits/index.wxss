.benefits-page {
  padding: 24rpx 24rpx 180rpx;
}

.benefit-hero {
  margin: -24rpx -24rpx 0;
  padding: 28rpx 0 42rpx;
  background: #241f1d;
}

.level-swiper {
  height: 336rpx;
}

.level-swiper swiper-item {
  box-sizing: border-box;
  padding: 0 8rpx;
}

.level-card {
  min-height: 310rpx;
  padding: 30rpx;
  border-radius: 18rpx;
  background: linear-gradient(135deg, #7b675c 0%, #c6a27e 100%);
  color: #fff;
}

.level-card.silver {
  background: linear-gradient(135deg, #7b7672 0%, #d8d0c7 100%);
}

.level-card.gold {
  background: linear-gradient(135deg, #7b675c 0%, #c6a27e 100%);
}

.level-card.platinum {
  background: linear-gradient(135deg, #4e4b4a 0%, #b8aaa0 100%);
}

.level-card.diamond {
  background: linear-gradient(135deg, #191817 0%, #6f645c 52%, #e5d2bd 100%);
}

.level-tag {
  font-size: 24rpx;
  font-weight: 800;
}

.level-title {
  margin-top: 58rpx;
  font-size: 36rpx;
  font-weight: 880;
  line-height: 1.18;
}

.level-note {
  margin-top: 14rpx;
  color: rgba(255, 255, 255, 0.82);
  font-size: 23rpx;
  font-weight: 650;
  line-height: 1.45;
}

.benefit-progress {
  height: 12rpx;
  margin-top: 22rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.28);
}

.benefit-progress view {
  height: 100%;
  border-radius: 999rpx;
  background: #fff;
}

.progress-copy {
  margin-top: 10rpx;
  text-align: right;
  color: rgba(255, 255, 255, 0.82);
  font-size: 22rpx;
  font-weight: 750;
}

.benefit-section {
  margin-top: 34rpx;
}

.benefit-title {
  color: #342b28;
  font-size: 32rpx;
  font-weight: 850;
}

.benefit-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 26rpx 12rpx;
  margin-top: 24rpx;
}

.benefit-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  text-align: center;
}

.benefit-icon {
  width: 62rpx;
  height: 62rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f1e7df;
  color: #8a684c;
  font-size: 24rpx;
  font-weight: 850;
}

.benefit-item text {
  color: #5e514b;
  font-size: 21rpx;
  font-weight: 650;
  line-height: 1.3;
}

.gift-card {
  margin-top: 16rpx;
  padding: 22rpx 24rpx;
  display: grid;
  grid-template-columns: 190rpx 1fr;
  align-items: center;
  gap: 18rpx;
  border-color: #d3b189;
  background: linear-gradient(90deg, #f0dcc6 0%, #fff 62%);
}

.gift-card view {
  color: #8a684c;
  font-size: 26rpx;
  font-weight: 800;
}

.gift-card text {
  min-height: 66rpx;
  padding: 0 18rpx;
  border: 1rpx solid #d3b189;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #7a5738;
  font-size: 25rpx;
  font-weight: 850;
  text-align: center;
}
