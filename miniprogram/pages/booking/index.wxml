<view wx:if="{{service}}" class="page booking-page">
  <view wx:if="{{stylePreset}}" class="style-preset card">
    <image class="sp-img" src="{{stylePreset.image}}" mode="aspectFill"></image>
    <view class="sp-info">
      <view class="sp-t">{{lang === 'en' ? 'Booking this style' : '预约同款'}}</view>
      <view class="sp-d">{{lang === 'en' ? 'Reference photo attached' : '参考图已带上'}}{{stylePreset.techName ? (stylePreset.techMatched ? ' · 指定技师 ' + stylePreset.techName : ' · 原作者 ' + stylePreset.techName + '(该服务不可选,已用默认技师)') : ''}}</view>
    </view>
  </view>
  <view class="booking-service card">
    <image class="mini-visual" src="{{service.image}}" mode="aspectFill"></image>
    <view class="booking-service-info">
      <view class="service-name">{{service.name}}</view>
      <view class="muted">{{service.duration}}{{t.minutes}} · {{t.deposit}} CAD ${{service.depositAmount}}</view>
    </view>
  </view>

  <view class="section">
    <view class="section-head">
      <view class="section-title">{{t.time}}</view>
    </view>
    <view class="form-card card">
      <picker mode="selector" range="{{technicians}}" range-key="name" value="{{technicianIndex}}" bindchange="bindTechnicianChange">
        <view class="picker-row technician-row">
          <view>
            <text class="picker-label">{{lang === 'en' ? 'Artist' : '服务技师'}}</text>
            <text class="picker-sub">{{lang === 'en' ? 'Tap to select artist' : '点击选择服务人员'}}</text>
          </view>
          <view class="picker-right">
            <text class="picker-value">{{technician.name || 'Mia Chen'}}</text>
            <text class="chevron">›</text>
          </view>
        </view>
      </picker>
      <picker mode="date" value="{{appointmentDate}}" start="{{minDate}}" bindchange="bindDateChange">
        <view class="picker-row">
          <view>
            <text class="picker-label">{{t.date}}</text>
            <text class="picker-sub">{{lang === 'en' ? 'Tap to choose date' : '点击选择到店日期'}}</text>
          </view>
          <view class="picker-right">
            <text class="picker-value">{{appointmentDate}}</text>
            <text class="chevron">›</text>
          </view>
        </view>
      </picker>
      <view class="slot-grid">
        <block wx:for="{{timeSlots}}" wx:key="*this">
          <button class="slot {{appointmentTime === item ? 'active' : ''}}" bindtap="chooseTime" data-time="{{item}}">{{item}}</button>
        </block>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-head">
      <view class="section-title">{{t.addOns}}</view>
      <view class="section-note">{{t.optional}}</view>
    </view>
    <view class="addon-grid">
      <block wx:for="{{addOns}}" wx:key="id">
        <button class="addon card {{item.checked ? 'active' : ''}}" bindtap="toggleAddon" data-id="{{item.id}}">
          <text>{{item.name}}</text>
          <text class="muted">+CAD ${{item.price}}</text>
        </button>
      </block>
    </view>
  </view>

  <view class="section">
    <view class="section-head">
      <view class="section-title">{{t.reference}}</view>
      <view class="section-note">{{referenceImages.length}}/3</view>
    </view>
    <view class="image-list">
      <block wx:for="{{referenceImages}}" wx:key="*this">
        <view class="image-wrap">
          <image class="ref-image" src="{{item}}" mode="aspectFill"></image>
          <button class="remove-image" bindtap="removeImage" data-index="{{index}}">×</button>
        </view>
      </block>
      <button class="upload-box card" bindtap="chooseImage">
        <text class="upload-plus">＋</text>
        <text>{{t.upload}}</text>
      </button>
    </view>
    <view class="ai-reference-card card">
      <view>
        <view class="ai-title">{{lang === 'en' ? 'AI Style Suggestion' : 'AI 款式建议'}}</view>
        <view class="ai-text">{{lang === 'en' ? 'AI can estimate complexity before artist confirmation.' : 'AI 可先判断参考图复杂度，最终美甲报价仍需人工确认。'}}</view>
      </view>
      <button class="ai-btn" bindtap="analyzeReference" disabled="{{!referenceImages.length || isAnalyzingReference}}">
        {{isAnalyzingReference ? (lang === 'en' ? 'Analyzing' : '分析中') : (lang === 'en' ? 'Analyze' : 'AI 分析')}}
      </button>
      <view wx:if="{{referenceAnalysis}}" class="ai-result">
        <view>{{lang === 'en' ? 'Complexity' : '复杂度'}}：{{referenceAnalysis.complexity || '-'}}</view>
        <view>{{lang === 'en' ? 'Suggested price' : '价格建议'}}：{{referencePriceText}}</view>
        <view>{{referenceMessage}}</view>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-head">
      <view class="section-title">{{t.remark}}</view>
      <view class="section-note">{{remark.length}}/100</view>
    </view>
    <textarea class="remark card" maxlength="100" placeholder="{{t.remarkPlaceholder}}" value="{{remark}}" bindinput="inputRemark"></textarea>
  </view>

  <view class="bottom-bar">
    <view class="summary">
      <text class="muted">{{t.requiredDeposit}}</text>
      <text class="price">CAD ${{service.depositAmount}}</text>
    </view>
    <button class="btn btn-ghost" bindtap="addToCart">{{cartId ? t.save : t.addToCart}}</button>
    <button class="btn btn-primary" bindtap="checkoutNow">{{t.checkout}}</button>
  </view>
</view>
