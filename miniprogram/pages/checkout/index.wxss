.first-head {
  margin-bottom: 18rpx;
}

.checkout-item {
  display: block;
  padding: 16rpx;
  margin-bottom: 18rpx;
}

.mini-visual {
  width: 100%;
  height: 238rpx;
  margin-top: 16rpx;
  display: block;
  border-radius: 14rpx;
}

.checkout-info {
  width: 100%;
}

.checkout-title {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  color: #342b28;
  font-size: 31rpx;
  font-weight: 850;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.checkout-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
}

.checkout-status {
  flex: none;
  color: #c39b76;
  font-size: 24rpx;
  font-weight: 760;
}

.checkout-time-row,
.checkout-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 12rpx;
  color: #8a7f78;
  font-size: 25rpx;
  font-weight: 700;
}

.cost-card,
.store-box {
  padding: 24rpx;
}

.cost-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 76rpx;
  border-bottom: 1rpx solid #f0e8e1;
}

.cost-row:last-child {
  border-bottom: none;
}

.switch-row {
  min-height: 98rpx;
}

.store-name {
  margin-bottom: 12rpx;
  font-size: 30rpx;
  font-weight: 750;
}

.store-box .muted {
  margin-top: 10rpx;
}

.remark {
  width: 100%;
  height: 160rpx;
  padding: 22rpx;
  line-height: 1.5;
}

.pay-btn {
  width: 310rpx;
}
