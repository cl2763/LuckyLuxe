.first-head {
  margin-bottom: 18rpx;
}

.checkout-item {
  display: flex;
  gap: 18rpx;
  align-items: flex-start;
  padding: 16rpx;
  margin-bottom: 18rpx;
  box-sizing: border-box;
}

.mini-visual {
  width: 150rpx;
  height: 150rpx;
  flex: none;
  display: block;
  border-radius: 14rpx;
}

.checkout-info {
  flex: 1;
  min-width: 0;
}

.checkout-title {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  color: #342b28;
  font-size: 31rpx;
  font-weight: 850;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.checkout-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
}

.checkout-status {
  flex: none;
  color: #c39b76;
  font-size: 24rpx;
  font-weight: 760;
}

.checkout-time-row,
.checkout-meta {
  display: grid;
  gap: 6rpx;
  margin-top: 12rpx;
  color: #8a7f78;
  font-size: 23rpx;
  font-weight: 700;
}

.cost-card,
.store-box {
  padding: 24rpx;
}

.cost-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 76rpx;
  border-bottom: 1rpx solid #f0e8e1;
}

.cost-row:last-child {
  border-bottom: none;
}

.switch-row {
  min-height: 98rpx;
}

.store-name {
  margin-bottom: 12rpx;
  font-size: 30rpx;
  font-weight: 750;
}

.store-box .muted {
  margin-top: 10rpx;
}

.deposit-policy {
  padding: 24rpx;
}

.deposit-policy-title {
  color: #342b28;
  font-size: 30rpx;
  font-weight: 850;
}

.deposit-policy-text {
  margin-top: 12rpx;
  color: #8a7f78;
  font-size: 24rpx;
  font-weight: 720;
  line-height: 1.55;
}

.remark {
  width: 100%;
  height: 160rpx;
  padding: 22rpx;
  line-height: 1.5;
}

.pay-btn {
  width: 240rpx;
  min-width: 0;
}
