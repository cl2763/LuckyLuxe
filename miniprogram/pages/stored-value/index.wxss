page{background:#fbf8f5}
.pg{padding:22rpx 26rpx 60rpx}
.hero{background:#2d2826;border-radius:18rpx;padding:30rpx 26rpx;color:#fff}
.row{display:flex;justify-content:space-between;align-items:center}
.hl{font-size:23rpx;color:#d8c6b3}
.lv{font-size:20rpx;color:#e7c9a4;background:#c8a47e22;border:1rpx solid #c8a47e44;border-radius:40rpx;padding:2rpx 14rpx}
.hv{font-size:58rpx;font-weight:700;color:#e7c9a4;margin:10rpx 0 14rpx}
.charge{text-align:center;background:#c8a47e;color:#fff;border-radius:12rpx;padding:18rpx 0;font-size:25rpx}
.t2{font-size:25rpx;font-weight:600;color:#2d2826;margin:20rpx 4rpx 12rpx}
.demo{font-size:19rpx;color:#b5731f;background:#fff4e6;border:1rpx solid #f0d9b8;border-radius:20rpx;padding:1rpx 12rpx;margin-left:8rpx;font-weight:400}
.card{background:#fff;border:1rpx solid #e7ddd4;border-radius:16rpx;padding:18rpx;margin-bottom:12rpx}
.sp{display:flex;justify-content:space-between;align-items:center}
.pn{font-size:25rpx;font-weight:600;color:#2d2826}
.ps{font-size:21rpx;color:#8c8279;margin-top:5rpx}
.buy{font-size:23rpx;color:#fff;background:#c8a47e;border-radius:40rpx;padding:8rpx 24rpx}
.list{background:#fff;border:1rpx solid #e7ddd4;border-radius:16rpx;overflow:hidden}
.li{display:flex;align-items:center;justify-content:space-between;padding:20rpx 22rpx;border-bottom:1rpx solid #f1e7df}
.li:last-child{border-bottom:none}
.li-main{flex:1;min-width:0}
.li-t{font-size:25rpx;color:#2d2826}
.li-d{font-size:21rpx;color:#8c8279;margin-top:5rpx}
.li-v{font-size:25rpx;font-weight:600}
.li-v.up{color:#47735f}
.li-v.down{color:#a34c48}
.empty{background:#fff;border:1rpx solid #e7ddd4;border-radius:16rpx;padding:40rpx 30rpx;text-align:center;color:#b6a99b;font-size:22rpx;line-height:1.6}
.note{font-size:21rpx;color:#b6a99b;line-height:1.6;margin-top:18rpx}
