.home-page {
  padding-top: 22rpx;
}

.language-switch {
  display: flex;
  width: 190rpx;
  margin: 0 0 18rpx auto;
  padding: 6rpx;
  border: 1rpx solid #eadfd7;
  border-radius: 999rpx;
  background: #fff;
}

.lang-option {
  flex: 1;
  height: 52rpx;
  border-radius: 999rpx;
  color: #8a7f78;
  font-size: 23rpx;
  font-weight: 760;
}

.lang-option.active {
  background: #2b2b2b;
  color: #fff;
}

.hero {
  display: flex;
  min-height: 520rpx;
  padding: 34rpx;
  border-radius: 24rpx;
  background: #2b2b2b;
  color: #fff;
}

.hero-copy {
  position: relative;
  z-index: 2;
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.brand-mark {
  width: 78rpx;
  height: 78rpx;
  margin-bottom: 44rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.55);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ead8cc;
  font-weight: 700;
}

.eyebrow {
  color: #ead8cc;
  font-size: 23rpx;
  text-transform: uppercase;
}

.hero-title {
  margin-top: 12rpx;
  font-size: 64rpx;
  font-weight: 800;
  letter-spacing: 0;
}

.hero-text {
  margin-top: 14rpx;
  color: rgba(255, 255, 255, 0.76);
}

.hero-actions {
  display: flex;
  gap: 18rpx;
  margin-top: 40rpx;
}

.hero-btn {
  width: 180rpx;
  height: 78rpx;
}

.hero-visual {
  width: 210rpx;
  height: 452rpx;
  margin-left: 20rpx;
  border-radius: 18rpx;
  display: block;
}

.quick-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 14rpx;
}

.quick-item {
  min-width: 0;
  height: 148rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 14rpx;
  font-size: 24rpx;
}

.quick-icon {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f3ebe4;
  color: #c6a27e;
  font-size: 22rpx;
  font-weight: 700;
}

.service-scroll {
  white-space: nowrap;
}

.recommend-card {
  display: inline-block;
  width: 292rpx;
  margin-right: 18rpx;
  padding: 14rpx;
  text-align: left;
  vertical-align: top;
}

.recommend-visual {
  width: 100%;
  height: 190rpx;
  display: block;
  border-radius: 14rpx;
}

.recommend-name {
  margin-top: 18rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-weight: 700;
}

.recommend-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 10rpx;
  color: #8a7f78;
  font-size: 24rpx;
}

.store-card {
  overflow: hidden;
}

.store-visual {
  width: 100%;
  height: 230rpx;
  display: block;
  border-radius: 16rpx 16rpx 0 0;
}

.store-info {
  padding: 26rpx;
}

.store-name {
  margin-bottom: 12rpx;
  font-size: 34rpx;
  font-weight: 750;
}

.store-row {
  margin-top: 14rpx;
  color: #5e514b;
  font-size: 25rpx;
}

.store-btn {
  margin-top: 24rpx;
}
