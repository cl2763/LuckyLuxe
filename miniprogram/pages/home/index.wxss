.home-page {
  --home-edge: 24rpx;
  padding: 24rpx var(--home-edge) 180rpx;
  overflow-x: hidden;
  box-sizing: border-box;
}

.home-section-container {
  width: 100%;
  max-width: 100%;
  margin-right: 0;
  margin-left: 0;
  box-sizing: border-box;
}

.home-landing {
  width: 100%;
  max-width: 100%;
  min-height: 0;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
}

.top-row {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 22rpx;
}

.brand-lockup {
  display: flex;
  align-items: center;
  gap: 16rpx;
  min-width: 0;
}

.brand-logo {
  width: 62rpx;
  height: 62rpx;
  border-radius: 50%;
  background: #1f1f1f;
  flex: none;
}

.brand-name {
  color: #241f1d;
  font-size: 32rpx;
  font-weight: 850;
  line-height: 1.1;
}

.brand-sub {
  margin-top: 5rpx;
  color: #8a7f78;
  font-size: 20rpx;
  font-weight: 600;
}

.language-switch {
  display: flex;
  width: 164rpx;
  flex: none;
  padding: 6rpx;
  border: 1rpx solid #eadfd7;
  border-radius: 999rpx;
  background: #fff;
}

.lang-option {
  flex: 1;
  height: 48rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #8a7f78;
  font-size: 22rpx;
  font-weight: 760;
  line-height: 1;
}

.lang-option.active {
  background: #2b2b2b;
  color: #fff;
}

.hero {
  width: 100%;
  flex: none;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  min-height: 0;
  padding: 22rpx;
  border-radius: 22rpx;
  background: #2b2b2b;
  color: #fff;
  overflow: hidden;
  box-sizing: border-box;
}

.hero-copy {
  position: relative;
  z-index: 2;
  display: block;
  width: 100%;
}

.brand-mark {
  width: 78rpx;
  height: 78rpx;
  margin-bottom: 44rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.55);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ead8cc;
  font-weight: 700;
}

.eyebrow {
  color: #ead8cc;
  font-size: 22rpx;
  font-weight: 760;
  text-transform: uppercase;
}

.hero-title {
  margin-top: 12rpx;
  font-size: 50rpx;
  font-weight: 800;
  letter-spacing: 0;
}

.hero-text {
  margin-top: 14rpx;
  color: rgba(255, 255, 255, 0.76);
  font-size: 25rpx;
  line-height: 1.45;
}

.hero-actions {
  display: flex;
  gap: 18rpx;
  margin-top: 24rpx;
}

.hero-btn {
  flex: 1;
  min-width: 0;
  height: 72rpx;
  font-size: 25rpx;
}

.hero-swiper {
  width: 100%;
  flex: none;
  min-height: 390rpx;
  height: 390rpx;
  margin-top: 22rpx;
  border-radius: 18rpx;
  overflow: hidden;
  background: #1f1f1f;
}

.hero-visual {
  width: 100%;
  height: 100%;
  display: block;
  border-radius: 18rpx;
}

.quick-section {
  display: block;
  width: 100%;
  margin-top: 18rpx;
}

.quick-row {
  width: 100%;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
}

.quick-item {
  min-width: 0;
  height: 118rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 14rpx;
  font-size: 24rpx;
}

.quick-icon {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f3ebe4;
  color: #c6a27e;
  font-size: 22rpx;
  font-weight: 700;
}

.portfolio-button {
  width: 100%;
  min-width: 100%;
  max-width: 100%;
  margin-top: 14rpx;
  min-height: 108rpx;
  padding: 20rpx 22rpx;
  display: grid;
  grid-template-columns: 58rpx 1fr 34rpx;
  align-items: center;
  gap: 18rpx;
  text-align: left;
  align-self: stretch;
  box-sizing: border-box;
}

.home-page .section {
  width: 100%;
  max-width: 100%;
  margin-top: 28rpx;
  box-sizing: border-box;
}

.home-page .section-head {
  margin-bottom: 10rpx;
}

.portfolio-copy {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  min-width: 0;
}

.portfolio-copy text:first-child {
  color: #342b28;
  font-size: 30rpx;
  font-weight: 850;
}

.portfolio-copy text:last-child {
  color: #8a7f78;
  font-size: 23rpx;
  font-weight: 600;
  line-height: 1.35;
}

.portfolio-arrow {
  color: #c6a27e;
  font-size: 50rpx;
  line-height: 1;
  text-align: right;
}

.recommend-grid {
  width: 100%;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.recommend-card {
  display: block;
  width: 100%;
  min-width: 0;
  padding: 14rpx;
  text-align: left;
  box-sizing: border-box;
}

.recommend-visual {
  width: 100%;
  height: 170rpx;
  display: block;
  border-radius: 14rpx;
}

.recommend-name {
  margin-top: 18rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-weight: 700;
}

.recommend-meta {
  display: grid;
  gap: 6rpx;
  margin-top: 10rpx;
  color: #8a7f78;
  font-size: 23rpx;
  line-height: 1.25;
}

.store-card {
  width: 100%;
  overflow: hidden;
  box-sizing: border-box;
}

.store-visual {
  width: 100%;
  height: 230rpx;
  display: block;
  border-radius: 16rpx 16rpx 0 0;
}

.store-info {
  padding: 26rpx;
}

.store-name {
  margin-bottom: 12rpx;
  font-size: 34rpx;
  font-weight: 750;
}

.store-row {
  margin-top: 14rpx;
  color: #5e514b;
  font-size: 25rpx;
}

.store-btn {
  margin-top: 24rpx;
}

.shop-bar {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin: 14rpx 0 4rpx;
  padding: 14rpx 20rpx;
  background: #fff;
  border: 1rpx solid #e7ddd4;
  border-radius: 40rpx;
}

.shop-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #47735f;
  flex: none;
}

.shop-name {
  flex: 1;
  font-size: 23rpx;
  color: #2d2826;
  font-weight: 600;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.shop-switch {
  font-size: 22rpx;
  color: #9b7655;
  flex: none;
}
