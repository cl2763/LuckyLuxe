page{background:#fbf8f5}
.pg{padding:22rpx 26rpx 60rpx}
.hero{background:#2d2826;border-radius:18rpx;padding:34rpx 26rpx;color:#fff;text-align:center}
.hl{font-size:23rpx;color:#d8c6b3}
.hv{font-size:64rpx;font-weight:700;color:#e7c9a4;margin:8rpx 0 6rpx}
.hn{font-size:21rpx;color:#b6a99b}
.btns{display:flex;gap:14rpx;margin:16rpx 0}
.b{flex:1;text-align:center;font-size:25rpx;color:#8c8279;background:#fff;border:1rpx solid #e7ddd4;border-radius:14rpx;padding:22rpx 0}
.b.p{background:#c8a47e;color:#fff;border-color:#c8a47e}
.t2{font-size:25rpx;font-weight:600;color:#2d2826;margin:20rpx 4rpx 12rpx}
.empty{background:#fff;border:1rpx solid #e7ddd4;border-radius:16rpx;padding:50rpx 30rpx;text-align:center;color:#b6a99b;font-size:23rpx;line-height:1.6}
.demo{font-size:19rpx;color:#b5731f;background:#fff4e6;border:1rpx solid #f0d9b8;border-radius:20rpx;padding:1rpx 12rpx;margin-left:8rpx;font-weight:400}
.list{background:#fff;border:1rpx solid #e7ddd4;border-radius:16rpx;overflow:hidden}
.li{display:flex;align-items:center;justify-content:space-between;padding:22rpx 22rpx;border-bottom:1rpx solid #f1e7df}
.li:last-child{border-bottom:none}
.li-main{flex:1;min-width:0}
.li-t{font-size:25rpx;color:#2d2826}
.li-d{font-size:21rpx;color:#8c8279;margin-top:5rpx}
.li-v{font-size:26rpx;font-weight:600}
.li-v.up{color:#47735f}
.li-v.down{color:#a34c48}
