<view class="page cart-page">
  <block wx:if="{{cart.length}}">
    <block wx:for="{{cart}}" wx:key="_id">
      <view class="cart-card card">
        <button class="check {{item.selected ? 'checked' : ''}}" bindtap="toggleItem" data-id="{{item._id}}">{{item.selected ? '✓' : ''}}</button>
        <view class="cart-main">
          <view class="cart-info">
            <view class="cart-title-row">
              <text class="cart-title">{{item.service.name}}</text>
              <text class="cart-status">{{t.pendingCheckout}}</text>
            </view>
            <view class="cart-time-row">
              <text>{{item.appointmentInfo.date}}</text>
              <text>{{item.appointmentInfo.time}}</text>
              <text>{{item.service.duration}}{{t.minutes}}</text>
            </view>
            <view class="cart-meta">
              <text>{{t.deposit}} <text class="price">CAD ${{item.service.depositAmount}}</text></text>
              <text>{{t.servicePrice}} CAD ${{item.service.price}}</text>
            </view>
          </view>
          <image class="cart-visual" src="{{item.service.image}}" mode="aspectFill"></image>
          <view class="cart-actions">
            <button bindtap="editBooking" data-service-id="{{item.serviceId}}" data-id="{{item._id}}">{{t.edit}}</button>
            <button bindtap="removeItem" data-id="{{item._id}}">{{t.remove}}</button>
          </view>
        </view>
      </view>
    </block>
  </block>

  <view wx:else class="empty empty-cart">
    <view class="empty-title">{{t.emptyTitle}}</view>
    <view>{{t.emptyText}}</view>
    <button class="btn btn-primary empty-btn" bindtap="goServices">{{t.chooseService}}</button>
  </view>

  <view wx:if="{{cart.length}}" class="bottom-bar">
    <button class="all-check" bindtap="toggleAll">
      <text class="check mini {{allSelected ? 'checked' : ''}}">{{allSelected ? '✓' : ''}}</text>
      <text>{{t.selectAll}}</text>
    </button>
    <view class="bottom-fill">
      <view class="muted">{{t.totalDeposit}}</view>
      <view class="price">CAD ${{totalDeposit}}</view>
    </view>
    <button class="btn btn-primary checkout-btn" bindtap="goCheckout">{{t.checkout}}</button>
  </view>
</view>
