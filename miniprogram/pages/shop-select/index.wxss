page{background:#fbf8f5}
.pg{padding:30rpx 26rpx 60rpx}
.head{margin-bottom:24rpx}
.ht{font-size:34rpx;font-weight:600;color:#2d2826}
.hd{font-size:23rpx;color:#8c8279;margin-top:8rpx;line-height:1.6}
.scanbtn{text-align:center;font-size:26rpx;color:#fff;background:#c8a47e;border-radius:14rpx;padding:22rpx 0;margin-bottom:20rpx}
.empty{text-align:center;color:#8c8279;font-size:24rpx;padding:80rpx 0}
.shop{display:flex;align-items:center;gap:16rpx;background:#fff;border:1rpx solid #e7ddd4;border-radius:16rpx;padding:22rpx 20rpx;margin-bottom:14rpx}
.sav{width:72rpx;height:72rpx;border-radius:16rpx;background:#f1e7df;color:#9b7655;display:flex;align-items:center;justify-content:center;font-size:30rpx;font-weight:600;flex:0 0 auto}
.sinfo{flex:1;min-width:0}
.sname{font-size:28rpx;font-weight:600;color:#2d2826}
.saddr{font-size:22rpx;color:#8c8279;margin-top:6rpx}
.chev{color:#c8b8a8;font-size:32rpx}
