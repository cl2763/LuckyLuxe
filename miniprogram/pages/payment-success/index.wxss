.success-page {
  display: flex;
  flex-direction: column;
}

.success-panel {
  margin-top: 40rpx;
  padding: 56rpx 34rpx;
  text-align: center;
}

.success-icon {
  width: 108rpx;
  height: 108rpx;
  margin: 0 auto 24rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #c6a27e;
  color: #fff;
  font-size: 58rpx;
  font-weight: 800;
}

.success-title {
  margin-bottom: 14rpx;
  font-size: 40rpx;
  font-weight: 800;
}

.summary-card {
  margin-top: 24rpx;
  padding: 20rpx 26rpx;
}

.summary-row {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0e8e1;
  color: #5e514b;
}

.summary-row:last-child {
  border-bottom: none;
}

.summary-row text:last-child {
  max-width: 390rpx;
  text-align: right;
  color: #3a2e2a;
}

.success-actions {
  display: grid;
  grid-template-columns: 1fr;
  gap: 18rpx;
  margin-top: 32rpx;
}
